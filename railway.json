{
  "build": {
    "builder": "dockerfile",
    "dockerfilePath": "backend/Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyMaxRetries": 5,
    "healthchecks": {
      "readiness": {
        "path": "/health",
        "interval": 10,
        "timeout": 5
      }
    },
    "startCommand": "/app/purptape-api"
  }
}
