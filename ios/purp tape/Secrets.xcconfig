// Build Secrets Configuration
// For local development with real credentials:
// 1. Copy Secrets.xcconfig.example to Secrets.xcconfig
// 2. Replace placeholder values with your actual Supabase credentials
// 3. Do NOT commit credentials to git
//
// For CI/staging builds, this placeholder file is used.
// Get your real Supabase credentials from: https://app.supabase.com

SUPABASE_URL = https://placeholder.supabase.co
SUPABASE_ANON_KEY = sb_placeholder_key
