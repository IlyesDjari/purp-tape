// Build Secrets Configuration Template
// 
// INSTRUCTIONS:
// 1. Copy this file and name it "Secrets.xcconfig"
// 2. Replace the placeholder values with your actual credentials
// 3. Secrets.xcconfig is in .gitignore and WILL NOT be committed
// 4. Get credentials from: https://app.supabase.com/project/[YOUR-PROJECT]/settings/general

// Public credentials (safe to commit via build config)
// Used for client-side authentication
SUPABASE_URL = https://your-project-name.supabase.co
SUPABASE_ANON_KEY = sb_publishable_your_anon_key_here

// 🚫 IMPORTANT: NEVER add SUPABASE_SECRET_KEY to client app!
// Secret keys must stay in your backend only.
// If accidentally exposed, rotate it immediately at:
// https://app.supabase.com/project/[YOUR-PROJECT]/settings/api
