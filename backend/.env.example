# Server Configuration
PORT=8080
HOST=0.0.0.0
ENV=development

# Database
DATABASE_URL=postgres://purptape:devpassword123@localhost:5432/purptape?sslmode=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# Supabase Authentication
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SECRET_KEY=your-service-role-key-here

# Cloudflare R2
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_BUCKET_NAME=purptape-audio
R2_ACCOUNT_ID=your-account-id

# FinOps
FINOPS_STORAGE_COST_PER_GB_MONTH=0.015
FINOPS_MONTHLY_BUDGET_USD=25
FINOPS_BUDGET_GUARD_ENABLED=false
FINOPS_UPLOAD_BLOCK_ENABLED=false
FINOPS_BUDGET_GUARD_RATIO=1.0
FINOPS_ENFORCE_R2_LIFECYCLE=false
FINOPS_R2_LIFECYCLE_STRICT=false
FINOPS_COST_INGEST_TOKEN=

# Background job scalability
JOB_WORKER_CONCURRENCY=4
JOB_BATCH_SIZE=32

# JWT Secret (for token generation if not using Supabase Auth)
JWT_SECRET=your-secret-key-here
